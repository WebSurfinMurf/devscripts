#!/bin/bash
# claudeauto - Launch Claude in full auto mode
# Usage: claudeauto [project-name] [initial-prompt]
#
# Full auto mode:
#   --dangerously-skip-permissions: Skip all permission prompts
#   Checks and auto-fixes ~/.claude/settings.json for autonomous mode
#   If no project specified, starts in ~/projects directory
#
# Examples:
#   claudeauto                    # Start in projects dir, full auto
#   claudeauto nginx              # Start in nginx project, full auto
#   claudeauto nginx "fix bug"    # Start with specific prompt

SETTINGS_FILE="$HOME/.claude/settings.json"

# --- Check if using native installer (not stale npm global) ---
check_claude_installation() {
  local current_claude
  current_claude=$(which claude 2>/dev/null)

  if [ -z "$current_claude" ]; then
    echo ""
    echo "  ╔══════════════════════════════════════════════════════════════╗"
    echo "  ║  Claude Code not found. Install the native version:        ║"
    echo "  ║                                                            ║"
    echo "  ║    curl -fsSL https://claude.ai/install.sh | bash          ║"
    echo "  ╚══════════════════════════════════════════════════════════════╝"
    echo ""
    sleep 5
    return
  fi

  # Resolve symlinks to find the real binary
  local real_path
  real_path=$(readlink -f "$current_claude" 2>/dev/null || echo "$current_claude")

  # Native install lives under ~/.local/share/claude/versions/
  if [[ "$real_path" == *"/.local/share/claude/versions/"* ]]; then
    return  # Using native installer, all good
  fi

  # Using npm global or some other non-native install
  local current_ver
  current_ver=$(claude --version 2>/dev/null | head -1)
  echo ""
  echo "  WARNING: Using non-native Claude Code ($current_ver)"
  echo "  Location: $current_claude"
  echo ""
  echo "  Run these to switch to the native version (auto-updates):"
  echo ""
  echo "    claude install"
  echo "    sudo npm uninstall -g @anthropic-ai/claude-code"
  echo ""
  echo "  Continuing in 5 seconds..."
  sleep 5
}

# --- Ensure settings.json is configured for full autonomous mode ---
ensure_autonomous_settings() {
  # Create ~/.claude if it doesn't exist
  mkdir -p "$HOME/.claude"

  # Required settings for full autonomous mode
  local REQUIRED_SETTINGS='{
    "permissions": {"defaultMode": "bypassPermissions"},
    "skipDangerousModePermissionPrompt": true,
    "sandbox": {
      "enabled": true,
      "autoAllowBashIfSandboxed": true,
      "allowUnsandboxedCommands": true,
      "excludedCommands": ["docker"]
    }
  }'

  # If settings file doesn't exist, create with autonomous config
  if [ ! -f "$SETTINGS_FILE" ]; then
    echo "$REQUIRED_SETTINGS" | python3 -m json.tool > "$SETTINGS_FILE"
    echo "[claudeauto] Created $SETTINGS_FILE with autonomous settings"
    return
  fi

  # Check and fix settings using python3 (always available)
  local result
  result=$(python3 -c "
import json, sys

required = json.loads('''$REQUIRED_SETTINGS''')

try:
    with open('$SETTINGS_FILE') as f:
        cfg = json.load(f)
except (json.JSONDecodeError, FileNotFoundError):
    print('corrupt')
    sys.exit(0)

changed = []

# permissions.defaultMode
cfg.setdefault('permissions', {})
if cfg['permissions'].get('defaultMode') != 'bypassPermissions':
    cfg['permissions']['defaultMode'] = 'bypassPermissions'
    changed.append('permissions.defaultMode')

# skipDangerousModePermissionPrompt
if cfg.get('skipDangerousModePermissionPrompt') is not True:
    cfg['skipDangerousModePermissionPrompt'] = True
    changed.append('skipDangerousModePermissionPrompt')

# sandbox settings
req_sandbox = required['sandbox']
cur_sandbox = cfg.get('sandbox', {})
if cur_sandbox != req_sandbox:
    # Merge required sandbox keys (preserve any extras user added)
    cfg.setdefault('sandbox', {})
    for k, v in req_sandbox.items():
        if cfg['sandbox'].get(k) != v:
            cfg['sandbox'][k] = v
            changed.append(f'sandbox.{k}')

if changed:
    with open('$SETTINGS_FILE', 'w') as f:
        json.dump(cfg, f, indent=2)
        f.write('\n')
    print(','.join(changed))
else:
    print('')
" 2>/dev/null)

  if [ "$result" = "corrupt" ]; then
    echo "[claudeauto] WARNING: $SETTINGS_FILE is corrupt/invalid JSON. Rebuilding..."
    echo "$REQUIRED_SETTINGS" | python3 -m json.tool > "$SETTINGS_FILE"
    echo "[claudeauto] Recreated $SETTINGS_FILE"
    return
  fi

  if [ -n "$result" ]; then
    echo "[claudeauto] Fixed settings: $result"
  fi
}

# --- Ensure tmux scrollback is at least 6000 lines ---
check_tmux_scrollback() {
  [ -z "$TMUX" ] && return  # Not in tmux

  local current
  current=$(tmux show-option -gqv history-limit 2>/dev/null)
  current=${current:-2000}  # tmux default is 2000

  if [ "$current" -lt 6000 ] 2>/dev/null; then
    tmux set-option -g history-limit 6000
    echo "[claudeauto] Increased tmux scrollback: $current -> 6000 lines"
  fi
}

ensure_autonomous_settings
check_claude_installation
check_tmux_scrollback

# --- Navigate to project directory ---
PROJECT="$1"
PROMPT="$2"

if [ -z "$PROJECT" ]; then
  cd "$HOME/projects"
else
  [ ! -d "$HOME/projects/$PROJECT" ] && echo "Project not found: $PROJECT" && exit 1
  cd "$HOME/projects/$PROJECT"
fi

# Launch Claude with full auto mode (no permission prompts)
claude --dangerously-skip-permissions --permission-mode bypassPermissions --allow-dangerously-skip-permissions ${PROMPT:+"$PROMPT"}
